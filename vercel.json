{
  "crons": [
    {"path": "/api/cron?action=in", "schedule": "30 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "35 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "40 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "45 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "50 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "55 3 * * 1-5"},
    {"path": "/api/cron?action=in", "schedule": "0 4 * * 1-5"},
    {"path": "/api/cron?action=refresh", "schedule": "30 6 * * 1-5"},
    {"path": "/api/cron?action=refresh", "schedule": "30 9 * * 1-5"},
    {"path": "/api/cron?action=refresh", "schedule": "30 12 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "0 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "5 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "10 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "15 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "20 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "25 13 * * 1-5"},
    {"path": "/api/cron?action=out", "schedule": "30 13 * * 1-5"}
  ],
  "builds": [
    {
      "src": "api/cron.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/cron",
      "dest": "api/cron.py"
    }
  ]
}
