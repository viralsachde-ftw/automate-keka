# Minimal env config for Keka automation

# Redis/Vercel KV URL (required in production)
KV_URL=redis://default:your-password@your-redis-host:6379
# or REDIS_URL=redis://default:your-password@your-redis-host:6379

# Clock type: web (WFO) or remote (WFH). Default: web
KEKA_CLOCK_TYPE=web

# Optional: timezone (default Asia/Kolkata)
KEKA_TIMEZONE=Asia/Kolkata

# Optional: log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
